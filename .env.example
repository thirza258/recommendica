SECRET_KEY=your-secret-key
OPENAI_API_KEY=
DEVELOPMENT_MODE=True
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=True

# ChromaDB
RE_CHROMA_HOST=localhost
RE_CHROMA_PORT=8040

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
DEFAULT_LLM_MODEL=google/gemma-4-26b-a4b-it

# ── AI / RAG Pipeline ───────────────────────────────────────────────────────

# Embedding
OLLAMA_EMBEDDING_MODEL=embeddinggemma
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# LLM
DENSE_LLM_MODEL=google/gemini-3-flash-preview
LLM_TEMPERATURE=0

# Retrieval
TOP_K=5
CANDIDATE_MULTIPLIER=4
CHUNK_SIZE=5
COLLECTION_NAME=arxiv_collection

# Rerank (leave empty to disable)
RERANK_MODEL=
RERANK_TOP_N=

# Query-transform models
HYDE_MODEL=mistralai/mistral-nemo
STEP_BACK_MODEL=anthropic/claude-sonnet-4-6
RAG_FUSION_MODEL=anthropic/claude-sonnet-4-6
RAG_FUSION_N_VARIANTS=4

# Confidence gate
CONFIDENCE_ALPHA=0.5
CONFIDENCE_BETA=0.3
CONFIDENCE_GAMMA=0.2
CONFIDENCE_THRESHOLD=0.75
